{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "scripts": {
    "build": "nuxt build --dotenv .env.production",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "bun lint:eslint && bun lint:prettier",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . --check",
    "lint:typecheck": "nuxi typecheck",
    "lint:full": "bun lint && bun lint:typecheck",
    "lint:fix": "eslint . --fix && prettier --write --list-different ."
  },
  "dependencies": {
    "@internationalized/date": "=3.7.0",
    "@nuxt/icon": "1.12.0",
    "@nuxtjs/i18n": "9.5.5",
    "@pinia/nuxt": "^0.11.1",
    "@tailwindcss/vite": "^4.1.11",
    "@upstash/redis": "^1.35.1",
    "google-auth-library": "^9.15.1",
    "nuxt-vue3-google-signin": "^0.0.11",
    "h3": "^1.15.3",
    "jsonwebtoken": "^9.0.2",
    "reka-ui": "^2.3.2",
    "vaul-vue": "^0.4.1",
    "tailwindcss": "^4.1.11",
    "uuid": "^11.1.0",
    "nuxt": "^3.17.6",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@iconify-json/material-symbols": "^1.2.29",
    "@nuxt/eslint": "^1.5.2",
    "@nuxtjs/device": "^3.2.4",
    "@tauri-apps/cli": "^2.6.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@vueuse/nuxt": "^13.5.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.12"
  }
}
