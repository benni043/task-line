{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "scripts": {
    "build": "nuxt build --dotenv .env.production",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . --check",
    "lint:typecheck": "nuxi typecheck",
    "lint:full": "npm run lint && npm run lint:typecheck",
    "lint:fix": "eslint . --fix && prettier --write --list-different .",
    "test": "cross-env NUXT_ENV=test playwright test"
  },
  "dependencies": {
    "@internationalized/date": "=3.7.0",
    "@nuxt/icon": "^1.15.0",
    "@nuxtjs/i18n": "^9.5.6",
    "@pinia/nuxt": "^0.11.2",
    "@tailwindcss/vite": "^4.1.12",
    "@upstash/redis": "^1.35.3",
    "google-auth-library": "^10.2.1",
    "h3": "^1.15.4",
    "jsonwebtoken": "^9.0.2",
    "marked": "^16.2.0",
    "nuxt": "^3.18.1",
    "nuxt-vue3-google-signin": "^0.0.11",
    "pinia": "^3.0.3",
    "reka-ui": "^2.4.1",
    "std-env": "^3.9.0",
    "tailwindcss": "^4.1.12",
    "unstorage": "^1.16.1",
    "uuid": "^11.1.0",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1",
    "vue3-google-signin": "^2.1.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@iconify-json/material-symbols": "^1.2.32",
    "@nuxt/eslint": "^1.9.0",
    "@nuxt/test-utils": "^3.19.2",
    "@nuxtjs/device": "^3.2.4",
    "@playwright/test": "^1.54.2",
    "@tauri-apps/cli": "^2.8.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@vueuse/nuxt": "^13.7.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.9.2",
    "vue-tsc": "^3.0.5"
  }
}
